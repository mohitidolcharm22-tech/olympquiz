# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/olympquiz
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/olympquiz

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_USE_openssl_rand_hex_64_different
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Production example:
# ALLOWED_ORIGINS=https://olympquiz.com,https://www.olympquiz.com

