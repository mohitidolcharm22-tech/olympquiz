# ─── API ─────────────────────────────────────────────────────────────────────
# IMPORTANT: must be an ABSOLUTE URL including the https:// (or http://) scheme.
# Without the scheme the browser treats it as a relative path and prepends the
# Vercel origin, producing broken requests like
#   https://your-app.vercel.app/oylmpbackend-production.up.railway.app/auth/login
#
# Local dev
VITE_API_URL=http://localhost:5000/api/v1
# Production (Vercel) — example
# VITE_API_URL=https://oylmpbackend-production.up.railway.app/api/v1

# ─── YouTube Data API v3 ──────────────────────────────────────────────────────
# Used to validate that YouTube URLs linked as video lessons are educational.
# Get your key at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Enable "YouTube Data API v3" → Create credentials → API key
# Restrict the key to: YouTube Data API v3 + HTTP referrers (your Vercel domain)
#
VITE_YOUTUBE_API_KEY=AIza...your_key_here
